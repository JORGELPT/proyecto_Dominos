<?xml version="1.0" encoding="UTF-8"?>
<!-- Adaptado del template Flower_Landscape para DOMINO'S PIZZA -->
<!-- Colores del sistema: Azul principal #004AAD | Acento rojo #BE1E1E -->
<jasperReport name="Reporte_Empleados" language="java"
              pageWidth="842" pageHeight="595" orientation="Landscape"
              columnWidth="802" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20"
              uuid="c368610e-5bee-4e75-8f1e-ecda64380534">

    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="One Empty Record"/>

    <!-- ======= ESTILOS ======= -->
    <style name="Title"         forecolor="#FFFFFF"  fontName="Times New Roman" fontSize="42.0" bold="true"/>
    <style name="SubTitle"      forecolor="#FFFFFF"  fontName="Times New Roman" fontSize="16.0" bold="false"/>
    <style name="Column header" forecolor="#FFFFFF"  fontName="Times New Roman" fontSize="11.0" bold="true"/>
    <style name="Detail"        mode="Transparent"   fontName="Times New Roman"/>
    <style name="Row"           mode="Transparent"   fontName="Times New Roman" pdfFontName="Times-Roman">
        <!-- Fila alternada en azul muy claro -->
        <conditionalStyle mode="Opaque" backcolor="#E8F0FB">
            <conditionExpression><![CDATA[$V{REPORT_COUNT}%2 == 0]]></conditionExpression>
        </conditionalStyle>
    </style>

    <!-- Dataset para gráfico de pastel (decorativo) -->
    <dataset name="PieChartDataset" uuid="21b70311-b650-4678-a39c-887917366bf0"/>

    <!-- Sin query (los datos se inyectan desde Java) -->
    <query language="sql"><![CDATA[
        SELECT p.cedula, p.nombre, p.tel,
               c.nombre_cargo  AS cargo,
               e.horario,
               e.salario,
               d.nombre_departamento AS departamento
        FROM tbl_empleado e
        JOIN tbl_persona       p ON p.id_persona      = e.id_persona
        LEFT JOIN tbl_cargo      c ON c.id_cargo        = e.id_cargo
        LEFT JOIN tbl_departamento d ON d.id_departamento = c.id_departamento
        ORDER BY p.nombre
    ]]></query>

    <!-- Campos del dataset -->
    <field name="cedula"        class="java.lang.String"/>
    <field name="nombre"        class="java.lang.String"/>
    <field name="tel"           class="java.lang.String"/>
    <field name="cargo"         class="java.lang.String"/>
    <field name="horario"       class="java.lang.String"/>
    <field name="salario"       class="java.lang.Double"/>
    <field name="departamento"  class="java.lang.String"/>

    <variable name="totalEmpleados" class="java.lang.Integer" calculation="Count">
        <expression><![CDATA[$F{cedula}]]></expression>
    </variable>

    <!-- ================================================================ -->
    <!-- BACKGROUND: gráfico de pastel decorativo con colores del sistema  -->
    <!-- ================================================================ -->
    <background height="555" splitType="Stretch">
        <!-- Gráfico de pastel decorativo (esquina inferior izquierda) -->
        <element kind="chart" chartType="pie3D"
                 uuid="9c2b39f8-7bbb-400b-a7b5-08065f7181e7"
                 x="-18" y="406" width="229" height="139"
                 showLegend="false" evaluationTime="Report">
            <dataset kind="pie">
                <datasetRun uuid="48bc4196-bec0-438e-a7c8-f74180b4f441"
                            subDataset="PieChartDataset">
                    <dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.JREmptyDataSource(5)]]></dataSourceExpression>
                </datasetRun>
                <series>
                    <keyExpression><![CDATA[$V{REPORT_COUNT}]]></keyExpression>
                    <valueExpression><![CDATA[new Double(200 * Math.random() * 5)]]></valueExpression>
                </series>
            </dataset>
            <plot backgroundAlpha="0.4" foregroundAlpha="0.85">
                <itemLabel color="#000000" backgroundColor="#FFFFFF"/>
                <!-- Tonalidades azul del sistema #004AAD -->
                <seriesColor order="0" color="#004AAD"/>
                <seriesColor order="1" color="#1A5FBD"/>
                <seriesColor order="2" color="#0039A6"/>
                <seriesColor order="3" color="#3374CC"/>
                <seriesColor order="4" color="#004A94"/>
                <seriesColor order="5" color="#BE1E1E"/>
            </plot>
        </element>

        <!-- Logo pizza (esquina superior izquierda, solo pág 1) -->
        <element kind="image" uuid="20bb2440-c413-4a05-a706-a10d8c847aba"
                 x="-20" y="65" width="210" height="200">
            <printWhenExpression><![CDATA[$V{PAGE_NUMBER} == 1]]></printWhenExpression>
            <expression><![CDATA["pizza1-removebg-preview.png"]]></expression>
        </element>

        <!-- Logo pizza (páginas siguientes) -->
        <element kind="image" uuid="5a4947cf-88fa-4c35-83d8-b8d2e9d03edc"
                 x="-20" y="-20" width="210" height="200">
            <printWhenExpression><![CDATA[$V{PAGE_NUMBER} > 1]]></printWhenExpression>
            <expression><![CDATA["pizza1-removebg-preview.png"]]></expression>
        </element>
    </background>

    <!-- ================================================================ -->
    <!-- TITLE: barra azul con nombre de la pizzería                       -->
    <!-- ================================================================ -->
    <title height="94" splitType="Stretch">

        <!-- Barra azul principal -->
        <element kind="frame" uuid="83f5e806-cc04-4161-87a9-07633f604bc1"
                 mode="Opaque" x="-20" y="0" width="842" height="65"
                 forecolor="#004AAD" backcolor="#004AAD">

            <!-- Nombre de la pizzería -->
            <element kind="staticText" uuid="f5cd9ee0-5caa-4e48-8946-c7e84d82a845"
                     x="200" y="4" width="580" height="56"
                     fontSize="42.0" bold="true" hTextAlign="Right" style="Title">
                <text><![CDATA[DOMINO'S PIZZA]]></text>
            </element>

            <!-- Emoji pizza decorativo -->
            <element kind="staticText" uuid="aa001122-0000-0000-0000-000000000001"
                     x="10" y="8" width="60" height="50"
                     fontSize="36.0" hTextAlign="Center" style="Title">
                <text><![CDATA[🍕]]></text>
            </element>
        </element>

        <!-- Subtítulo: nombre del reporte -->
        <element kind="staticText" uuid="0dae0af3-dd1d-4b42-b346-386af21f0689"
                 x="227" y="68" width="575" height="24"
                 fontSize="15.0" bold="false" hTextAlign="Right" style="SubTitle"
                 forecolor="#004AAD">
            <text><![CDATA[Reporte de Consulta de Empleados  —  Sistema de Gestión]]></text>
        </element>

    </title>

    <!-- ================================================================ -->
    <!-- PAGE HEADER (vacío, solo separación)                             -->
    <!-- ================================================================ -->
    <pageHeader splitType="Stretch"/>

    <!-- ================================================================ -->
    <!-- COLUMN HEADER: encabezados de la tabla                           -->
    <!-- ================================================================ -->
    <columnHeader height="20" splitType="Stretch">
        <element kind="frame" uuid="2a3d298d-90eb-4db1-919a-c9b2ed28c222"
                 mode="Opaque" x="227" y="0" width="575" height="20"
                 forecolor="#004AAD" backcolor="#004AAD">

            <element kind="staticText" uuid="ch-cedula"
                     x="2" y="2" width="80" height="16"
                     forecolor="#FFFFFF" fontName="Times New Roman" fontSize="11.0" bold="true"
                     style="Column header">
                <text><![CDATA[Cédula]]></text>
            </element>
            <element kind="staticText" uuid="ch-nombre"
                     x="84" y="2" width="130" height="16"
                     forecolor="#FFFFFF" fontName="Times New Roman" fontSize="11.0" bold="true"
                     style="Column header">
                <text><![CDATA[Nombre]]></text>
            </element>
            <element kind="staticText" uuid="ch-telefono"
                     x="216" y="2" width="80" height="16"
                     forecolor="#FFFFFF" fontName="Times New Roman" fontSize="11.0" bold="true"
                     style="Column header">
                <text><![CDATA[Teléfono]]></text>
            </element>
            <element kind="staticText" uuid="ch-cargo"
                     x="298" y="2" width="90" height="16"
                     forecolor="#FFFFFF" fontName="Times New Roman" fontSize="11.0" bold="true"
                     style="Column header">
                <text><![CDATA[Cargo]]></text>
            </element>
            <element kind="staticText" uuid="ch-horario"
                     x="390" y="2" width="70" height="16"
                     forecolor="#FFFFFF" fontName="Times New Roman" fontSize="11.0" bold="true"
                     style="Column header">
                <text><![CDATA[Horario]]></text>
            </element>
            <element kind="staticText" uuid="ch-salario"
                     x="462" y="2" width="55" height="16"
                     forecolor="#FFFFFF" fontName="Times New Roman" fontSize="11.0" bold="true"
                     hTextAlign="Right" style="Column header">
                <text><![CDATA[Salario]]></text>
            </element>
            <element kind="staticText" uuid="ch-depto"
                     x="519" y="2" width="54" height="16"
                     forecolor="#FFFFFF" fontName="Times New Roman" fontSize="11.0" bold="true"
                     style="Column header">
                <text><![CDATA[Dpto.]]></text>
            </element>
        </element>
    </columnHeader>

    <!-- ================================================================ -->
    <!-- DETAIL: fila de datos                                            -->
    <!-- ================================================================ -->
    <detail>
        <band height="15" splitType="Stretch">

            <!-- Línea separadora inferior -->
            <element kind="line" uuid="ad4e998c-7071-4467-b7fa-4441cc53d3f6"
                     positionType="FixRelativeToBottom" x="227" y="14" width="575" height="1">
                <pen lineWidth="0.5" lineColor="#004AAD"/>
            </element>

            <!-- Frame de fila (alternado vía estilo Row) -->
            <element kind="frame" uuid="822bafe9-34ee-4b4f-aa76-3eae029c4911"
                     x="227" y="0" width="575" height="14" style="Row">

                <element kind="textField" uuid="det-cedula"
                         x="2" y="1" width="80" height="12" style="Detail">
                    <expression><![CDATA[$F{cedula}]]></expression>
                </element>
                <element kind="textField" uuid="det-nombre"
                         x="84" y="1" width="130" height="12" style="Detail">
                    <expression><![CDATA[$F{nombre}]]></expression>
                </element>
                <element kind="textField" uuid="det-telefono"
                         x="216" y="1" width="80" height="12" style="Detail">
                    <expression><![CDATA[$F{tel}]]></expression>
                </element>
                <element kind="textField" uuid="det-cargo"
                         x="298" y="1" width="90" height="12" style="Detail">
                    <expression><![CDATA[$F{cargo}]]></expression>
                </element>
                <element kind="textField" uuid="det-horario"
                         x="390" y="1" width="70" height="12" style="Detail">
                    <expression><![CDATA[$F{horario}]]></expression>
                </element>
                <element kind="textField" uuid="det-salario"
                         x="462" y="1" width="55" height="12"
                         hTextAlign="Right" pattern="#,##0.00" style="Detail">
                    <expression><![CDATA[$F{salario}]]></expression>
                </element>
                <element kind="textField" uuid="det-depto"
                         x="519" y="1" width="54" height="12" style="Detail">
                    <expression><![CDATA[$F{departamento}]]></expression>
                </element>
            </element>

        </band>
    </detail>

    <!-- ================================================================ -->
    <!-- COLUMN FOOTER                                                    -->
    <!-- ================================================================ -->
    <columnFooter height="7" splitType="Stretch">
        <element kind="line" uuid="c23ffbf7-1928-41f8-ade3-5930d9a4871d"
                 positionType="FixRelativeToBottom" x="227" y="3" width="575" height="1">
            <pen lineWidth="0.5" lineColor="#004AAD"/>
        </element>
    </columnFooter>

    <!-- ================================================================ -->
    <!-- PAGE FOOTER: barra azul con fecha, total y número de página      -->
    <!-- ================================================================ -->
    <pageFooter height="20" splitType="Stretch">
        <element kind="frame" uuid="6f4fe8ef-88ca-4d5d-b46a-054826bb7893"
                 mode="Opaque" x="2" y="0" width="838" height="20"
                 forecolor="#004AAD" backcolor="#004AAD">

            <!-- Fecha actual -->
            <element kind="textField" uuid="footer-fecha"
                     x="4" y="2" width="200" height="16"
                     forecolor="#FFFFFF" fontName="Arial" fontSize="11.0"
                     pattern="dd 'de' MMMM 'de' yyyy" vTextAlign="Middle"
                     style="Column header">
                <expression><![CDATA[new java.util.Date()]]></expression>
            </element>

            <!-- Nombre empresa centrado -->
            <element kind="staticText" uuid="footer-empresa"
                     x="270" y="2" width="300" height="16"
                     forecolor="#FFFFFF" fontName="Arial" fontSize="11.0"
                     hTextAlign="Center" vTextAlign="Middle" bold="true"
                     style="Column header">
                <text><![CDATA[🍕  DOMINO'S PIZZA — Sistema de Gestión]]></text>
            </element>

            <!-- Página X de Y -->
            <element kind="textField" uuid="footer-pagof"
                     x="673" y="2" width="80" height="16"
                     forecolor="#FFFFFF" fontName="Arial" fontSize="11.0"
                     hTextAlign="Right" vTextAlign="Middle" style="Column header">
                <expression><![CDATA["Página " + $V{PAGE_NUMBER} + " de"]]></expression>
            </element>
            <element kind="textField" uuid="footer-pagnum"
                     x="755" y="2" width="40" height="16"
                     forecolor="#FFFFFF" fontName="Arial" fontSize="11.0"
                     evaluationTime="Report" vTextAlign="Middle" style="Column header">
                <expression><![CDATA[" " + $V{PAGE_NUMBER}]]></expression>
            </element>

        </element>
    </pageFooter>

    <!-- ================================================================ -->
    <!-- SUMMARY: total de empleados                                       -->
    <!-- ================================================================ -->
    <summary splitType="Stretch">
        <band height="28">
            <element kind="frame" uuid="summary-frame"
                     mode="Opaque" x="227" y="4" width="575" height="20"
                     forecolor="#E8F0FB" backcolor="#E8F0FB">
                <element kind="staticText" uuid="summary-lbl"
                         x="2" y="2" width="160" height="16"
                         forecolor="#004AAD" fontName="Times New Roman" fontSize="11.0" bold="true">
                    <text><![CDATA[Total de empleados registrados:]]></text>
                </element>
                <element kind="textField" uuid="summary-total"
                         x="164" y="2" width="60" height="16"
                         forecolor="#BE1E1E" fontName="Times New Roman" fontSize="11.0" bold="true">
                    <expression><![CDATA[$V{totalEmpleados}]]></expression>
                </element>
            </element>
        </band>
    </summary>

</jasperReport>
