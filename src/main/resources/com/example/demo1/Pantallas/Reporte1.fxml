<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefWidth="900.0" prefHeight="600.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.demo1.Controllers.CONTROLLER_Reporte1">

    <!-- FONDO -->
    <Region AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0"
            style="-fx-background-image: url('/com/example/demo1/imagenes/fondop.png');
                   -fx-background-size: cover; -fx-background-position: center;"/>

    <VBox spacing="16.0"
          AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0">

        <!-- ===== ENCABEZADO: LOGO + NOMBRE PIZZERÍA ===== -->
        <HBox alignment="CENTER_LEFT" spacing="14.0"
              style="-fx-background-color: rgba(0,74,173,0.90);
                     -fx-background-radius: 12;
                     -fx-padding: 14 20 14 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 10, 0, 0, 4);">

            <!-- Logo pizza -->
            <Label text="🍕" style="-fx-font-size: 40px;"/>

            <!-- Nombre y subtítulo -->
            <VBox spacing="2.0">
                <Label text="DOMINO'S PIZZA" textFill="white">
                    <font><Font name="System Bold" size="22.0"/></font>
                </Label>
                <Label text="Sistema de Gestión" textFill="#cce0ff">
                    <font><Font size="11.0"/></font>
                </Label>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Título del reporte centrado -->
            <VBox alignment="CENTER" spacing="2.0">
                <Label text="CONSULTA DE EMPLEADOS" textFill="white">
                    <font><Font name="System Bold" size="20.0"/></font>
                </Label>
                <Label text="Reporte #1" textFill="#cce0ff">
                    <font><Font size="11.0"/></font>
                </Label>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Fecha -->
            <Label fx:id="lblFechaReporte" text="--/--/----" textFill="#cce0ff">
                <font><Font size="12.0"/></font>
            </Label>

        </HBox>

        <!-- ===== PANEL PRINCIPAL ===== -->
        <VBox spacing="14.0" VBox.vgrow="ALWAYS"
              style="-fx-background-color: rgba(0,0,0,0.48);
                     -fx-background-radius: 14;
                     -fx-padding: 20;">

            <!-- Barra de búsqueda y acciones -->
            <HBox alignment="CENTER_LEFT" spacing="12.0">

                <Label text="Buscar empleado:" textFill="white">
                    <font><Font name="System Bold" size="13.0"/></font>
                </Label>

                <TextField fx:id="TXTbuscar" prefHeight="32.0" prefWidth="240.0"
                           promptText="Cédula o nombre..."
                           style="-fx-background-radius: 20;
                                  -fx-background-color: rgba(255,255,255,0.88);
                                  -fx-text-fill: #1a1a1a;
                                  -fx-font-size: 13px;
                                  -fx-padding: 0 15 0 15;"/>

                <Button onAction="#FnBuscar" prefHeight="32.0" prefWidth="40.0"
                        style="-fx-background-color: #c0392b;
                               -fx-text-fill: white;
                               -fx-background-radius: 50;
                               -fx-cursor: hand;
                               -fx-font-size: 14px;"
                        text="🔍"/>

                <Button onAction="#FnLimpiar" prefHeight="32.0" prefWidth="80.0"
                        style="-fx-background-color: #004aad;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 20;
                               -fx-cursor: hand;"
                        text="Limpiar"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button onAction="#FnExportarPDF" prefHeight="32.0" prefWidth="130.0"
                        style="-fx-background-color: #004aad;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 20;
                               -fx-cursor: hand;"
                        text="📄 Exportar PDF"/>

                <Button onAction="#FnCargarTodos" prefHeight="32.0" prefWidth="120.0"
                        style="-fx-background-color: #27ae60;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 20;
                               -fx-cursor: hand;"
                        text="↻ Ver Todos"/>

                <Button onAction="#FnVerGrafico" prefHeight="32.0" prefWidth="130.0"
                        style="-fx-background-color: #8e44ad;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 20;
                               -fx-cursor: hand;"
                        text="📊 Ver Gráfico"/>

            </HBox>

            <!-- Tabla de empleados -->
            <TableView fx:id="tablaEmpleados" VBox.vgrow="ALWAYS"
                       style="-fx-border-color: #004aad;
                              -fx-border-width: 2;
                              -fx-background-color: rgba(255,255,255,0.92);
                              -fx-background-radius: 8;">
                <columns>
                    <TableColumn fx:id="colCedula"    prefWidth="110.0" text="Cédula"/>
                    <TableColumn fx:id="colNombre"    prefWidth="200.0" text="Nombre"/>
                    <TableColumn fx:id="colTelefono"  prefWidth="120.0" text="Teléfono"/>
                    <TableColumn fx:id="colCargo"     prefWidth="130.0" text="Cargo"/>
                    <TableColumn fx:id="colHorario"   prefWidth="120.0" text="Horario"/>
                    <TableColumn fx:id="colSalario"   prefWidth="100.0" text="Salario"/>
                    <TableColumn fx:id="colDepartamento" prefWidth="140.0" text="Departamento"/>
                </columns>
                <placeholder>
                    <Label text="No hay empleados para mostrar." style="-fx-text-fill: #555555;"/>
                </placeholder>
            </TableView>

            <!-- Pie: contador de registros -->
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="Total registros:" textFill="#cce0ff">
                    <font><Font size="12.0"/></font>
                </Label>
                <Label fx:id="lblTotal" text="0" textFill="white">
                    <font><Font name="System Bold" size="12.0"/></font>
                </Label>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="DOMINO'S PIZZA — Reporte de Empleados" textFill="#6ea8fe">
                    <font><Font size="11.0"/></font>
                </Label>
            </HBox>

        </VBox>
    </VBox>
</AnchorPane>
