<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo1.HelloController">
    <children>
              <!-- Panel principal -->
              <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="331.0" prefWidth="542.0">
                  <children>

                      <!-- Título -->
                      <Label layoutX="14.0" layoutY="25.0" prefHeight="34.0" prefWidth="285.0" text="AGREGAR INGREDIENTE" textFill="#004aad">
                          <font>
                  <Font name="System Bold" size="18.0" />
               </font>
                      </Label>

                      <!-- Nombre -->
                      <Label layoutX="23.0" layoutY="59.0" text="Nombre">
                          <font>
                  <Font size="14.0" />
               </font>
                      </Label>
                      <PasswordField fx:id="TXTnombre" layoutX="23.0" layoutY="79.0" prefHeight="25.0" prefWidth="239.0" />

                      <!-- Cantidad en Stock -->
                      <Label layoutX="26.0" layoutY="113.0" text="Cantidad en Stock">
                          <font>
                  <Font size="14.0" />
               </font>
                      </Label>
                      <PasswordField fx:id="TXTcantidad" layoutX="23.0" layoutY="133.0" prefHeight="25.0" prefWidth="239.0" />

                      <!-- Imagen -->
                      <Label layoutX="26.0" layoutY="167.0" text="Imagen del Producto">
                          <font>
                  <Font size="14.0" />
               </font>
                      </Label>
                      <PasswordField fx:id="TXTimagen" layoutX="23.0" layoutY="187.0" prefHeight="25.0" prefWidth="239.0" />

                      <!-- Botones -->
                      <Button layoutX="25.0" layoutY="230.0" mnemonicParsing="false" onAction="#FnGuardar" style="-fx-background-color: #d4e6ff;" text="Guardar" textFill="#004aad" />
                      <Button layoutX="100.0" layoutY="230.0" mnemonicParsing="false" onAction="#FnBuscar" style="-fx-background-color: #d4e6ff;" text="Buscar" textFill="#004aad" />
                      <Button layoutX="175.0" layoutY="230.0" mnemonicParsing="false" onAction="#FnLimpiar" style="-fx-background-color: #d4e6ff;" text="Limpiar" textFill="#004aad" />

                  </children>
              </AnchorPane>
        <SplitPane dividerPositions="0.08761160714285716" prefHeight="400.0" prefWidth="600.0">
            <items>
                <!-- Barra lateral roja -->
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="397.0" prefWidth="60.0" style="-fx-background-color: #be1e1e;" />

                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="228.0" prefWidth="229.0">
                    <children>
                        <SplitPane layoutY="-8.0" orientation="VERTICAL" prefHeight="408.0" prefWidth="557.0" />
                    </children>
                </AnchorPane>
            </items>
        </SplitPane>
    </children>
</AnchorPane>
