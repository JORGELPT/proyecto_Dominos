<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefWidth="900.0" prefHeight="580.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.demo1.Controllers.CONTROLLER_Proveedor">

    <Region AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0" style="-fx-background-image: url('/com/example/demo1/imagenes/fondop.png'); -fx-background-size: cover; -fx-background-position: center;"/>

    <VBox spacing="15.0" styleClass="form-card"
          AnchorPane.topAnchor="30.0" AnchorPane.leftAnchor="40.0"
          AnchorPane.rightAnchor="40.0" AnchorPane.bottomAnchor="30.0" style="-fx-background-color: rgba(0,0,0,0.48); -fx-background-radius: 14; -fx-padding: 10;">
        <padding><Insets top="25.0" left="25.0" right="25.0" bottom="25.0"/></padding>

        <Label text="AGREGAR PROVEEDOR" textFill="white">
            <font><Font name="System Bold" size="24.0"/></font>
        </Label>

        <!-- FILA 1: Nombre | Email -->
        <HBox spacing="30.0">
            <VBox HBox.hgrow="ALWAYS" spacing="3.0">
                <Label text="Nombre" textFill="white">
                    <font><Font name="System Bold" size="14.0"/></font>
                </Label>
                <TextField fx:id="TXTnombre" prefHeight="32.0"
                           style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="3.0">
                <Label text="Email" textFill="white">
                    <font><Font name="System Bold" size="14.0"/></font>
                </Label>
                <TextField fx:id="TXTemail" promptText="example@gmail.com"
                           prefHeight="32.0"
                           style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;"/>
            </VBox>
        </HBox>

        <!-- FILA 2: Teléfono+RNC+Dirección | Descripción -->
        <HBox spacing="30.0">
            <VBox HBox.hgrow="ALWAYS" spacing="3.0">
                <Label text="Teléfono" textFill="white">
                    <font><Font name="System Bold" size="14.0"/></font>
                </Label>
                <TextField fx:id="TXTtelefono" prefHeight="32.0"
                           style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;"/>

                <Label text="RNC" textFill="white">
                    <font><Font name="System Bold" size="14.0"/></font>
                    <VBox.margin><Insets top="10.0"/></VBox.margin>
                </Label>
                <TextField fx:id="TXTrnc" promptText="Ej: 123-12-12"
                           prefHeight="32.0"
                           style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;"/>

                <Label text="Dirección" textFill="white">
                    <font><Font name="System Bold" size="14.0"/></font>
                    <VBox.margin><Insets top="10.0"/></VBox.margin>
                </Label>
                <TextField fx:id="TXTdireccion" prefHeight="32.0"
                           style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;"/>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" spacing="3.0">
                <Label text="Descripción" textFill="white">
                    <font><Font name="System Bold" size="14.0"/></font>
                </Label>
                <TextArea fx:id="TXTdescripcion"
                          style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;" VBox.vgrow="ALWAYS"/>
            </VBox>
        </HBox>

        <!-- BOTONES -->
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <padding><Insets top="10.0"/></padding>
            <Button text="Guardar" onAction="#FnGuardar"
                    prefWidth="80.0" prefHeight="32.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;"/>
            <Button text="Eliminar" onAction="#FnEliminar"
                    prefWidth="80.0" prefHeight="32.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Editar" onAction="#FnEditar"
                    prefWidth="80.0" prefHeight="32.0" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;"/>
            <Button text="🔍" onAction="#FnBuscar"
                    prefWidth="40.0" prefHeight="32.0" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 50; -fx-cursor: hand;"/>
        </HBox>

        <!-- TABLA -->
        <TableView fx:id="tablaProveedores" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colNombre"   prefWidth="200.0" text="Nombre"/>
                <TableColumn fx:id="colTelefono" prefWidth="150.0" text="Teléfono"/>
                <TableColumn fx:id="colRnc"      prefWidth="150.0" text="RNC"/>
            </columns>
        </TableView>

    </VBox>
</AnchorPane>


