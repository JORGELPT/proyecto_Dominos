<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefWidth="900.0" prefHeight="580.0" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.demo1.Controllers.CONTROLLER_Sucursal">

    <Region AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0" style="-fx-background-image: url('/com/example/demo1/imagenes/fondop.png'); -fx-background-size: cover; -fx-background-position: center;"/>

    <VBox spacing="15.0"
          AnchorPane.topAnchor="25.0" AnchorPane.leftAnchor="30.0"
          AnchorPane.rightAnchor="30.0" AnchorPane.bottomAnchor="20.0">

        <Label text="AGREGAR SUCURSAL" textFill="white">
            <font><Font name="System Bold" size="24.0"/></font>
        </Label>

        <!-- Fila 1: Nombre | Tipo de servicio -->
        <HBox spacing="30.0">
            <VBox HBox.hgrow="ALWAYS" spacing="3.0">
                <Label text="Nombre"><font><Font name="System Bold" size="14.0"/></font></Label>
                <TextField fx:id="TXTnombre" prefHeight="32.0"
                           style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="3.0">
                <Label text="Tipo de servicio"><font><Font name="System Bold" size="14.0"/></font></Label>
                <ComboBox fx:id="cmbTipoServicio" prefHeight="32.0" maxWidth="Infinity"
                          style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;"/>
            </VBox>
        </HBox>

        <!-- Dirección -->
        <VBox spacing="3.0">
            <Label text="Dirección"><font><Font name="System Bold" size="14.0"/></font></Label>
            <TextField fx:id="TXTdireccion" prefHeight="32.0"
                       style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;"/>
        </VBox>

        <!-- Botones -->
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <padding><Insets top="5.0"/></padding>
            <Button text="Enviar" onAction="#FnGuardar" prefWidth="80.0" prefHeight="32.0"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;"/>
            <Button text="Eliminar" onAction="#FnEliminar" prefWidth="80.0" prefHeight="32.0"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Editar" onAction="#FnEditar" prefWidth="80.0" prefHeight="32.0"
                    style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;"/>
            <Button text="🔍" onAction="#FnBuscar" prefWidth="40.0" prefHeight="32.0"
                    style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 50; -fx-cursor: hand;"/>
        </HBox>

        <!-- Tabla -->
        <TableView fx:id="tablaSucursales" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colNombre"    prefWidth="220.0" text="Nombre"/>
                <TableColumn fx:id="colTipo"      prefWidth="180.0" text="Tipo"/>
                <TableColumn fx:id="colDireccion" prefWidth="280.0" text="Dirección"/>
            </columns>
        </TableView>

    </VBox>
</AnchorPane>

