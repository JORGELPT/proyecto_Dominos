<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="580.0" prefWidth="900.0" style="-fx-background-color: linear-gradient(to bottom right, #004aad, #be1e1e);" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo1.Controllers.CONTROLLER_inicio">
    <children>

    <Region style="-fx-background-image: url('/com/example/demo1/imagenes/fondop.png'); -fx-background-size: cover; -fx-background-position: center;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />

        <!-- TÍTULO -->
        <Label layoutX="309.0" layoutY="30.0" text="¡BIENVENIDO!" textFill="WHITE">
            <font><Font name="System Bold" size="42.0" /></font>
        </Label>

        <!-- CONTENEDOR PRINCIPAL -->
        <HBox alignment="CENTER_LEFT" layoutX="41.0" layoutY="92.0" spacing="40.0" AnchorPane.bottomAnchor="58.0" AnchorPane.leftAnchor="41.0" AnchorPane.rightAnchor="39.0" AnchorPane.topAnchor="92.0">

            <Region />

            <!-- TARJETA: REGISTRAR PEDIDO -->
            <VBox alignment="CENTER" onMouseClicked="#abrirRegistrarPedido" prefHeight="580.0" spacing="20.0" style="-fx-background-color: #6ea8fe; -fx-background-radius: 12; -fx-border-color: black; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 12, 0, 0, 4);">
                <padding>
                    <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
                </padding>
            <ImageView fitHeight="179.0" fitWidth="216.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../imagenes/p1-removebg-preview.png" />
               </image></ImageView>
                <Label alignment="CENTER" text="Registrar un&#10;Pedido" textAlignment="CENTER" textFill="WHITE" wrapText="true">
                    <font><Font name="System Bold" size="22.0" /></font>
                </Label>
            </VBox>

            <!-- TARJETA: RECLAMACIÓN DE PEDIDO -->
            <VBox alignment="CENTER" onMouseClicked="#abrirReclamacion" prefHeight="580.0" spacing="20.0" style="-fx-background-color: #6ea8fe; -fx-background-radius: 12; -fx-border-color: black; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 12, 0, 0, 4);">
                <padding>
                    <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
                </padding>
            <ImageView fitHeight="204.0" fitWidth="185.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../imagenes/reporte.png" />
               </image></ImageView>
                <Label alignment="CENTER" text="Hacer una&#10;reclamación&#10;de Pedido" textAlignment="CENTER" textFill="WHITE" wrapText="true">
                    <font><Font name="System Bold" size="22.0" /></font>
                </Label>
            </VBox>

            <!-- TARJETA: REGISTRAR CLIENTE -->
            <VBox alignment="CENTER" onMouseClicked="#abrirRegistrarCliente" prefHeight="383.0" prefWidth="212.0" spacing="20.0" style="-fx-background-color: #6ea8fe; -fx-border-color: black; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 12, 0, 0, 4);">
                <padding>
                    <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
                </padding>
            <ImageView fitHeight="153.0" fitWidth="142.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../imagenes/cliente-removebg-preview.png" />
               </image></ImageView>
                <Label alignment="CENTER" text="Registrar cliente" textAlignment="CENTER" textFill="WHITE" wrapText="true">
                    <font><Font name="System Bold" size="22.0" /></font>
                </Label>
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

        </HBox>

    </children>
</AnchorPane>
