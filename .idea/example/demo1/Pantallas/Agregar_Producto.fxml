<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefWidth="900.0" prefHeight="580.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.demo1.Controllers.CONTROLLER_Producto">


    <Region AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0" style="-fx-background-image: url('/com/example/demo1/imagenes/fondop.png'); -fx-background-size: cover; -fx-background-position: center;"/>

    <VBox spacing="12.0"
          AnchorPane.topAnchor="25.0" AnchorPane.leftAnchor="30.0"
          AnchorPane.rightAnchor="30.0" AnchorPane.bottomAnchor="20.0"
          style="-fx-background-color: rgba(0,0,0,0.48); -fx-background-radius: 14; -fx-padding: 10;">
        <padding><Insets top="20.0" left="20.0" right="20.0" bottom="20.0"/></padding>

        <Label text="AGREGAR PRODUCTO" textFill="white">
            <font><Font name="System Bold" size="24.0"/></font>
        </Label>

        <!-- COLUMNAS PRINCIPALES -->
        <HBox spacing="40.0" VBox.vgrow="ALWAYS">

            <!-- COLUMNA IZQUIERDA -->
            <VBox spacing="10.0" HBox.hgrow="ALWAYS">

                <Label text="Nombre" textFill="white">
                    <font><Font name="System Bold" size="14.0"/></font>
                </Label>
                <TextField fx:id="Txtnombre" prefHeight="32.0"
                           style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;"/>

                <Label text="Precio (costo)" textFill="white">
                    <font><Font name="System Bold" size="14.0"/></font>
                </Label>
                <TextField fx:id="Txtprecio" prefHeight="32.0"
                           style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;"/>

                <!-- Tipo + Disponible -->
                <HBox spacing="20.0">
                    <VBox HBox.hgrow="ALWAYS" spacing="4.0">
                        <Label text="Tipo" textFill="white">
                            <font><Font name="System Bold" size="14.0"/></font>
                        </Label>
                        <ComboBox fx:id="cmbtipo" promptText="pizza, alitas, bebida, otro"
                                  prefHeight="32.0" maxWidth="Infinity"
                                  style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox spacing="4.0">
                        <Label text="¿Está disponible?" textFill="white">
                            <font><Font name="System Bold" size="14.0"/></font>
                        </Label>
                        <HBox spacing="15.0">
                            <RadioButton fx:id="rbSi" text="Sí" textFill="white" mnemonicParsing="false"/>
                            <RadioButton fx:id="rbNo" text="No" textFill="white" mnemonicParsing="false"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- Presentación + Porción -->
                <HBox spacing="20.0">
                    <VBox spacing="4.0">
                        <Label text="Presentación" textFill="white">
                            <font><Font name="System Bold" size="14.0"/></font>
                        </Label>
                        <RadioButton fx:id="rbPequeno"  text="Pequeño"  textFill="white" mnemonicParsing="false"/>
                        <RadioButton fx:id="rbMediana"  text="Mediano"  textFill="white" mnemonicParsing="false"/>
                        <RadioButton fx:id="rbGrande"   text="Grande"   textFill="white" mnemonicParsing="false"/>
                        <RadioButton fx:id="rbFamiliar" text="Familiar" textFill="white" mnemonicParsing="false"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" spacing="4.0">
                        <Label text="Porción(es)" textFill="white">
                            <font><Font name="System Bold" size="14.0"/></font>
                        </Label>
                        <TextField fx:id="txtporcion" promptText="Cantidad (ej. 2, 6...)"
                                   prefHeight="32.0"
                                   style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>

            </VBox>

            <!-- COLUMNA DERECHA -->
            <VBox spacing="10.0" HBox.hgrow="ALWAYS">

                <Label text="Ingrediente(s)" textFill="white">
                    <font><Font name="System Bold" size="14.0"/></font>
                </Label>
                <HBox spacing="30.0">
                    <VBox spacing="5.0">
                        <CheckBox fx:id="chkMasa"      text="Masa"      textFill="white" mnemonicParsing="false"/>
                        <CheckBox fx:id="chkSalsa"     text="Salsa"     textFill="white" mnemonicParsing="false"/>
                        <CheckBox fx:id="chkQueso"     text="Queso"     textFill="white" mnemonicParsing="false"/>
                        <CheckBox fx:id="chkPepperoni" text="Pepperoni" textFill="white" mnemonicParsing="false"/>
                        <CheckBox fx:id="chkMaiz"      text="Maíz"      textFill="white" mnemonicParsing="false"/>
                    </VBox>
                    <VBox spacing="5.0">
                        <CheckBox fx:id="chkSalchicha" text="Salchicha" textFill="white" mnemonicParsing="false"/>
                        <CheckBox fx:id="chkVegetales" text="Vegetales" textFill="white" mnemonicParsing="false"/>
                        <CheckBox fx:id="chkPina"      text="Piña"      textFill="white" mnemonicParsing="false"/>
                        <CheckBox fx:id="chkBebida"    text="Bebida"    textFill="white" mnemonicParsing="false"/>
                        <CheckBox fx:id="chkOtro"      text="Otro"      textFill="white" mnemonicParsing="false"/>
                    </VBox>
                </HBox>

                <Label text="Imagen del Producto" textFill="white">
                    <font><Font name="System Bold" size="14.0"/></font>
                </Label>
                <VBox alignment="CENTER" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: rgba(255,255,255,0.15); -fx-border-color: #aaa; -fx-border-style: dashed; -fx-border-width: 1; -fx-background-radius: 8;">
                    <Label fx:id="lblRutaImagen" text="Seleccionar Archivo" textFill="white">
                        <font><Font size="13.0"/></font>
                    </Label>
                    <Button text="Examinar..." onAction="#FnSeleccionarImagen"
                            style="-fx-background-color: white; -fx-border-color: #999; -fx-cursor: hand;">
                        <VBox.margin><Insets top="5.0"/></VBox.margin>
                    </Button>
                </VBox>

            </VBox>

        </HBox>

        <!-- BOTONES -->
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <padding><Insets top="5.0"/></padding>
            <Button text="Enviar" onAction="#FnGuardar"
                    prefWidth="80.0" prefHeight="32.0"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;"/>
            <Button text="Eliminar" onAction="#FnEliminar"
                    prefWidth="80.0" prefHeight="32.0"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Editar" onAction="#FnEditar"
                    prefWidth="80.0" prefHeight="32.0"
                    style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;"/>
            <Button text="🔍" onAction="#FnBuscar"
                    prefWidth="40.0" prefHeight="32.0"
                    style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 50; -fx-cursor: hand;"/>
        </HBox>

        <!-- TABLA -->
        <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colNombre" prefWidth="250.0" text="Nombre"/>
                <TableColumn fx:id="colTipo"   prefWidth="180.0" text="Tipo"/>
                <TableColumn fx:id="colPrecio" prefWidth="150.0" text="Precio"/>
            </columns>
        </TableView>

    </VBox>
</AnchorPane>
