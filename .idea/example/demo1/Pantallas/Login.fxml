<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane prefWidth="900.0" prefHeight="580.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo1.Controllers.CONTROLLER_Login">
   <ImageView fitHeight="489.0" fitWidth="885.0" pickOnBounds="true" preserveRatio="true" />

    <!-- FONDO: imagen de fondo igual que las demás pantallas -->

    <Region style="-fx-background-image: url('/com/example/demo1/imagenes/fondop.png'); -fx-background-size: cover; -fx-background-position: center;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />

    <HBox alignment="CENTER" spacing="40.0">
        <padding>
            <Insets bottom="20.0" left="40.0" right="40.0" top="20.0" />
        </padding>

        <!-- Tarjeta con pizza grande -->
        <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 15, 0, 0, 5);">
            <padding>
                <Insets bottom="50.0" left="60.0" right="60.0" top="50.0" />
            </padding>
            <Label style="-fx-font-size: 160px;" text="🍕" textFill="#d70000" />
            <Label text="DOMINO'S PIZZA">
                <font><Font name="System Bold" size="28.0" /></font>
            </Label>
            <Label text="Sistema de Gestión">
                <font><Font size="14.0" /></font>
            </Label>
        </VBox>

        <!-- Formulario de login -->
        <VBox alignment="CENTER_LEFT" prefHeight="500.0" spacing="18.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 15, 0, 0, 5);">
            <padding>
                <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
            </padding>

            <Label prefHeight="38.0" prefWidth="311.0" text="Iniciar Sesión" textAlignment="CENTER" textFill="white">
                <font><Font name="System Bold" size="26.0" /></font>
            </Label>

            <Label text="Ingresa tus credenciales para continuar">
                <font><Font size="16.0" /></font>
            </Label>

            <Region prefHeight="10.0" />

            <Label text="Usuario">
                <font><Font name="System Bold" size="13.0" /></font>
            </Label>
            <TextField fx:id="TXTusuario" prefHeight="38.0" style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;" />

            <Label text="Contraseña">
                <font><Font name="System Bold" size="13.0" /></font>
            </Label>
            <PasswordField fx:id="TXTcontrasena" onAction="#FnIniciarSesion" prefHeight="38.0" style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;" />

            <Region prefHeight="5.0" />

            <Button maxWidth="Infinity" onAction="#FnIniciarSesion" prefHeight="42.0" style="-fx-background-color: #004aad; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Iniciar Sesión" />

            <Label fx:id="lblError" text="" textFill="#be1e1e" wrapText="true">
                <font><Font size="12.0" /></font>
            </Label>

        </VBox>

    </HBox>
</StackPane>
