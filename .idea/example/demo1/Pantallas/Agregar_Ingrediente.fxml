<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="580.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo1.Controllers.CONTROLLER_Ingrediente">


    <Region AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0" style="-fx-background-image: url('/com/example/demo1/imagenes/fondop.png'); -fx-background-size: cover; -fx-background-position: center;"/>

    <VBox layoutX="40.0" layoutY="24.0" spacing="15.0" style="-fx-background-color: rgba(0,0,0,0.48); -fx-background-radius: 14; -fx-padding: 10;" styleClass="form-card" AnchorPane.bottomAnchor="36.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="24.0">
        <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>

        <!-- Título -->
        <Label text="AGREGAR INGREDIENTE" textFill="white">
            <font><Font name="System Bold" size="24.0" /></font>
        </Label>

        <!-- Nombre -->
        <VBox spacing="3.0">
            <Label text="Nombre" textFill="white"><font><Font name="System Bold" size="14.0" /></font></Label>
            <TextField fx:id="TXTnombre" prefHeight="32.0" promptText="Masa, salsa, queso..." style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;" />
        </VBox>

        <!-- Cantidad en Stock -->
        <VBox spacing="3.0">
            <Label text="Cantidad en Stock" textFill="white"><font><Font name="System Bold" size="14.0" /></font></Label>
            <TextField fx:id="TXTcantidad" prefHeight="32.0" promptText="Ej: 3000, 237..." style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;" />
        </VBox>

        <!-- Fila: Fecha de caducidad | Tipo de Ingr. -->
        <HBox spacing="20.0">
            <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                <Label text="Fecha de caducidad" textFill="white"><font><Font name="System Bold" size="14.0" /></font></Label>
                <TextField fx:id="TXTfecha" prefHeight="32.0" style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;" />
            </VBox>
            <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                <Label text="Tipo de Ingr." textFill="white"><font><Font name="System Bold" size="14.0" /></font></Label>
                <ComboBox fx:id="cmbTipo" maxWidth="Infinity" prefHeight="32.0" style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-font-size: 13px;" />
            </VBox>
        </HBox>

        <!-- Fila: Cant. Min. del Stock | Proveedor -->
        <HBox spacing="20.0">
            <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                <Label text="Cant. Min. del Stock" textFill="white"><font><Font name="System Bold" size="14.0" /></font></Label>
                <TextField fx:id="TXTcantMin" prefHeight="32.0" style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;" />
            </VBox>
            <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                <Label text="Proveedor" textFill="white"><font><Font name="System Bold" size="14.0" /></font></Label>
                <ComboBox fx:id="cmbProveedor" maxWidth="Infinity" prefHeight="32.0" style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-font-size: 13px;" />
            </VBox>
        </HBox>

        <!-- Botones -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <padding><Insets top="5.0" /></padding>
            <Button onAction="#FnGuardar" prefHeight="32.0" prefWidth="80.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" text="Enviar" />
            <Button onAction="#FnEliminar" prefHeight="32.0" prefWidth="80.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" text="Eliminar" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#FnEditar" prefHeight="32.0" prefWidth="80.0" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" text="Editar" />
            <Button onAction="#FnBuscar" prefHeight="32.0" prefWidth="40.0" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 50; -fx-cursor: hand;" text="🔍" />
        </HBox>

    </VBox>
</AnchorPane>
