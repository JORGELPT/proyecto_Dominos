<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="580.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo1.Controllers.CONTROLLER_Inv_Ingrediente">

    <Region AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0" style="-fx-background-image: url('/com/example/demo1/imagenes/fondop.png'); -fx-background-size: cover; -fx-background-position: center;"/>

    <HBox spacing="30.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">

        <!-- ========== COLUMNA DERECHA: ETIQUETA + CAMIÓN ========== -->
        <VBox alignment="TOP_CENTER" prefHeight="580.0" spacing="20.0">
            <padding>
                <Insets top="50.0" />
            </padding>

            <!-- "AGREGAR INGREDIENTE" + icono -->
            <HBox alignment="CENTER" spacing="10.0">
                <Label text="AGREGAR&#10;INGREDIENTE" textFill="white">
                    <font><Font name="System Bold" size="20.0" /></font>
                </Label>
                <Label style="-fx-font-size: 38px;" text="🍅" />
            </HBox>

            <!-- Botón "Aquí" -->
            <Button prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #b8d4ff; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 20; -fx-cursor: hand;" text="Aquí" />

            <Region VBox.vgrow="ALWAYS" />

            <!-- Camión decorativo -->
            <Label style="-fx-font-size: 140px;" text="🚚" />
   
           <!-- ========== COLUMNA IZQUIERDA: FORMULARIO ========== -->
           <VBox prefHeight="454.0" style="-fx-border-color: #000; -fx-border-width: 2; -fx-border-radius: 4;">
               <padding>
                   <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
               </padding>
   
               <!-- Título -->
               <Label text="AGREGAR INGREDIENTE" textFill="white">
                   <font>
                  <Font name="System Bold" size="22.0" />
               </font>
                   <VBox.margin>
                  <Insets bottom="20.0" />
               </VBox.margin>
               </Label>
   
               <!-- ===== Nombre ===== -->
               <Label text="Nombre">
                   <font>
                  <Font name="System Bold" size="14.0" />
               </font>
               </Label>
               <TextField fx:id="TXTnombre" prefHeight="32.0" promptText="Masa, salsa, queso…" style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;">
                   <VBox.margin>
                  <Insets bottom="12.0" top="3.0" />
               </VBox.margin>
               </TextField>
   
               <!-- ===== Cantidad en Stock ===== -->
               <Label text="Cantidad en Stock">
                   <font>
                  <Font name="System Bold" size="14.0" />
               </font>
               </Label>
               <TextField fx:id="TXTcantidad" prefHeight="32.0" promptText="Ej: 3000, 237…" style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;">
                   <VBox.margin>
                  <Insets bottom="15.0" top="3.0" />
               </VBox.margin>
               </TextField>
   
               <!-- ===== Fila: Fecha caducidad / Tipo de Ingrediente ===== -->
               <HBox spacing="20.0">
                   <VBox HBox.hgrow="ALWAYS">
                       <Label text="Fecha de caducidad">
                           <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                       </Label>
                       <TextField fx:id="TXTfechaCaducidad" prefHeight="32.0" promptText="YYYY-MM-DD" style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;">
                           <VBox.margin>
                        <Insets top="3.0" />
                     </VBox.margin>
                       </TextField>
                   </VBox>
                   <VBox HBox.hgrow="ALWAYS">
                       <Label text="Tipo de Ingr.">
                           <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                       </Label>
                       <ComboBox fx:id="cmbTipoIngrediente" maxWidth="Infinity" prefHeight="32.0" style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;">
                           <VBox.margin>
                        <Insets top="3.0" />
                     </VBox.margin>
                       </ComboBox>
                   </VBox>
               </HBox>
   
               <Region prefHeight="15.0" />
   
               <!-- ===== Fila: Cant Mín / Proveedor ===== -->
               <HBox spacing="20.0">
                   <VBox HBox.hgrow="ALWAYS">
                       <Label text="Cant. Mín. del Stock">
                           <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                       </Label>
                       <TextField fx:id="TXTcantMin" prefHeight="32.0" style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;">
                           <VBox.margin>
                        <Insets top="3.0" />
                     </VBox.margin>
                       </TextField>
                   </VBox>
                   <VBox HBox.hgrow="ALWAYS">
                       <Label text="Proveedor">
                           <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                       </Label>
                       <ComboBox fx:id="cmbProveedor" maxWidth="Infinity" prefHeight="32.0" style="-fx-background-color: rgba(255,255,255,0.88); -fx-background-radius: 8; -fx-text-fill: #1a1a1a; -fx-font-size: 13px;">
                           <VBox.margin>
                        <Insets top="3.0" />
                     </VBox.margin>
                       </ComboBox>
                   </VBox>
               </HBox>
   
               <Region prefHeight="25.0" />
   
               <!-- ===== BOTONES ===== -->
               <HBox alignment="CENTER_LEFT" spacing="10.0">
                   <Button onAction="#FnGuardar" prefHeight="32.0" prefWidth="80.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" text="Enviar" />
                   <Button onAction="#FnEliminar" prefHeight="32.0" prefWidth="80.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" text="Eliminar" />
   
                   <Region HBox.hgrow="ALWAYS" />
   
                   <Button onAction="#FnEditar" prefHeight="32.0" prefWidth="80.0" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" text="Editar" />
                   <Button onAction="#FnBuscar" prefHeight="32.0" prefWidth="40.0" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 50; -fx-cursor: hand;" text="🔍" />
               </HBox>
   
           </VBox>

        </VBox>

    </HBox>
</AnchorPane>

