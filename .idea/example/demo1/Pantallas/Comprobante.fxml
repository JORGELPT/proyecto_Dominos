<?xml version="1.0" encoding="UTF-8"?>

        <?import javafx.scene.control.*?>
        <?import javafx.scene.layout.*?>
        <?import javafx.scene.text.*?>

<AnchorPane prefWidth="900.0" prefHeight="580.0" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.demo1.Controllers.">

    <Region AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0" style="-fx-background-image: url('/com/example/demo1/imagenes/fondop.png'); -fx-background-size: cover; -fx-background-position: center;"/>
<children>

    <!-- Título -->
    <Label layoutX="30.0" layoutY="25.0" prefHeight="34.0" prefWidth="400.0"
           text="CONSULTA DE EMPLEADOS" textFill="white">
        <font><Font name="System Bold" size="22.0" /></font>
    </Label>

    <!-- Buscar -->
    <Label layoutX="30.0" layoutY="75.0" text="Buscar por cédula o nombre">
        <font><Font size="14.0" /></font>
    </Label>
    <TextField fx:id="TXTbuscar" layoutX="30.0" layoutY="95.0"
               prefHeight="28.0" prefWidth="320.0" />
    <Button layoutX="360.0" layoutY="95.0" mnemonicParsing="false"
            onAction="#FnBuscar"
            style="-fx-background-color: #d4e6ff;"
            text="Buscar" textFill="white"
            prefHeight="28.0" prefWidth="80.0" />

    <!-- Tabla -->
    <TableView fx:id="tablaEmpleados"
               layoutX="30.0" layoutY="145.0"
               prefWidth="900.0" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colCedula"   prefWidth="120.0" text="Cédula" />
            <TableColumn fx:id="colNombre"   prefWidth="220.0" text="Nombre" />
            <TableColumn fx:id="colTelefono" prefWidth="140.0" text="Teléfono" />
            <TableColumn fx:id="colCargo"   prefWidth="140.0" text="Cargo" />
            <TableColumn fx:id="colHorario"  prefWidth="140.0" text="Horario" />
            <TableColumn fx:id="colSalario"  prefWidth="120.0" text="Salario" />
        </columns>
    </TableView>

</children>
</AnchorPane>
